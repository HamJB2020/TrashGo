# VARIABLES DE ENTORNO - Frontend TrashGo

# ================================================
# API
# ================================================
# URL base de la API del backend
# Desarrollo: http://localhost:5000/api
# Producción: https://trashgo-backend.onrender.com/api

REACT_APP_API_URL=http://localhost:5000/api

# ================================================
# ENTORNO
# ================================================
# development = Logs detallados, Hot reload
# production = Bundled, optimizado

REACT_APP_ENV=development

# ================================================
# FEATURE FLAGS (Opcional)
# ================================================
# REACT_APP_ENABLE_NOTIFICATIONS=true
# REACT_APP_ENABLE_ANALYTICS=false

# ================================================
# GOOGLE MAPS (Opcional - Para mapa de direcciones)
# ================================================
# REACT_APP_GOOGLE_MAPS_API_KEY=AIzaSy...

# ================================================
# STRIPE (Opcional - Para pagos en frontend)
# ================================================
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
