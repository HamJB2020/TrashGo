# VARIABLES DE ENTORNO - Backend TrashGo

# BASE DE DATOS (MongoDB)
# MONGO_URI: Cadena de conexión a MongoDB
# Local: mongodb://localhost:27017/trashgo
# Atlas: mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/trashgo

MONGO_URI=mongodb://localhost:27017/trashgo

# SEGURIDAD - JSON Web Token (JWT)
# JWT_SECRET: Clave para firmar tokens (mínimo 32 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=tu_clave_secreta_minimo_32_caracteres_aqui

# JWT_EXPIRATION: Tiempo de validez del token (7d, 24h, 3600)
JWT_EXPIRATION=7d

# URL del frontend para CORS
FRONTEND_URL=http://localhost:3000

# Entorno: development o production
NODE_ENV=development

# Puerto del servidor
PORT=5000
