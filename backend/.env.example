# VARIABLES DE ENTORNO - Backend TrashGo

# ================================================
# BASE DE DATOS (Supabase PostgreSQL)
# ================================================
# Obtener estas credenciales desde dashboard Supabase:
# https://supabase.com -> Tu Proyecto -> Settings -> Database

DB_USER=postgres
DB_PASSWORD=tu_contraseña_supabase_aqui
DB_HOST=tu-proyecto.supabase.co
DB_PORT=5432
DB_NAME=postgres

# ================================================
# SEGURIDAD - JSON Web Token (JWT)
# ================================================
# JWT_SECRET: Clave para firmar tokens
# - Mínimo 32 caracteres
# - Caracteres aleatorios (mayús, minús, números, símbolos)
# - NO usar espacios
# - GUARDAR SEGURO (no pushearlo a GitHub)
# 
# Generar clave segura:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=tu_clave_secreta_minimo_32_caracteres_aleatorios_aqui_abc123xyz

# JWT_EXPIRATION: Cuánto tiempo válido el token
# Formatos: 7d (7 días), 24h (24 horas), 3600 (segundos)
JWT_EXPIRATION=7d

# ================================================
# FRONTEND (CORS)
# ================================================
# URL del frontend (Vercel en producción)
# Permite que CORS deje hacer requests desde este dominio

FRONTEND_URL=http://localhost:3000

# ================================================
# ENTORNO
# ================================================
# development = Logs detallados, errores con stack
# production = Logs mínimos, errores simples

NODE_ENV=development

# ================================================
# PUERTO
# ================================================
# Puerto donde corre el servidor Express
# En producción (Render), no modifiquer

PORT=5000

# ================================================
# STRIPE (OPCIONAL - Para pagos futuros)
# ================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ================================================
# TWILIO (OPCIONAL - Para SMS)
# ================================================
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890

# ================================================
# SENDGRID (OPCIONAL - Para emails)
# ================================================
# SENDGRID_API_KEY=SG...
# SENDGRID_FROM_EMAIL=noreply@trashgo.com

# ================================================
# LOGGING Y MONITOREO
# ================================================
# SENTRY_DSN=https://...  # Para error tracking (opcional)
# LOG_LEVEL=debug|info|warn|error

# ================================================
# CONFIGURACIÓN DE REDIS (OPCIONAL - Para cache)
# ================================================
# REDIS_URL=redis://localhost:6379
